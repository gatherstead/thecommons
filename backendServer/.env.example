# ── Database ────────────────────────────────────────────────────────────────
# Point this at a Neon dev branch so your local data is isolated from prod.
# Create a branch at console.neon.tech, then copy the connection string here.
DATABASE_URL=

# ── Django ───────────────────────────────────────────────────────────────────
# Any random string works for local dev (e.g. `openssl rand -hex 32`).
# Required in prod — settings/prod.py crashes at startup if missing.
DJANGO_SECRET_KEY=

# DJANGO_ENV is NOT needed locally — defaults to "dev" automatically.
# Set DJANGO_ENV=prod on the production VM (gunicorn systemd service).

# ── Ingestion pipeline ───────────────────────────────────────────────────────
GEMINI_API_KEY=
CRON_SECRET=
THE_COMMONS_API_KEY=
SAFETY_SCORE_THRESHOLD=0.3

# Ingestion source sharding — number of days over which active sources are spread.
# The daily cron computes shard N as (day_of_year % INGEST_SHARD_COUNT) and only
# polls sources where `id % INGEST_SHARD_COUNT == N`. Set to 1 (or unset) to poll
# every active source on every run.
INGEST_SHARD_COUNT=3

# ── Better Auth bridge ───────────────────────────────────────────────────────
# Django validates JWTs issued by Next.js via JWKS. In dev, point at the local
# Next dev server. In prod, point at https://www.thecommons.town.
BETTER_AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks
BETTER_AUTH_ISSUER=http://localhost:3000
BETTER_AUTH_AUDIENCE=

# ── Email (digest) ───────────────────────────────────────────────────────────
# dev.py uses console email backend — BREVO_API_KEY is only needed in prod.
BREVO_API_KEY=
DIGEST_FROM_EMAIL=digest@thecommons.town
SITE_URL=https://www.thecommons.town

# ── Broadcast (event syndication) ────────────────────────────────────────────
# Access codes: comma-separated label:code pairs, one per client. Each label is
# stamped on submissions; codes are validated constant-time and never logged.
BROADCAST_ACCESS_CODES=
BROADCAST_HEADLESS=true
BROADCAST_DRY_RUN_DEFAULT=false
BROADCAST_MAX_CONCURRENCY=1
BROADCAST_SCREENSHOT_DIR=/home/ubuntu/broadcast/screenshots
BROADCAST_DOWNLOAD_DIR=/home/ubuntu/broadcast/downloads
BROADCAST_TIMEOUT_MS=30000
# BROADCAST_ENABLE_MOCK=1  # dev only: registers the local mock_site adapter
# Add https://broadcast.thecommons.town to CORS_EXTRA_ORIGINS and CSRF_TRUSTED_ORIGINS in prod.
# Tier-2 site credentials (only when those adapters are enabled) — NEVER commit
# EVENTBRITE_EMAIL=   EVENTBRITE_PASSWORD=   ...
