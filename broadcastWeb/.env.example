# Base URL of the Django API (broadcast routes live under /broadcast/).
# Dev: http://127.0.0.1:8000 · Prod: https://api.thecommons.town
VITE_BROADCAST_API_BASE_URL=http://127.0.0.1:8000

# Chrome extension ID(s) for manual-review autofill (broadcastExtension/).
# Accepts one id, or several comma-separated — the app pings each and uses
# whichever is installed, so the dev (unpacked) and published builds can coexist.
# Dev: copy the ID shown on chrome://extensions after "Load unpacked".
# Published: jidmhdmlbjfnblbheglmodhpcjhafjmi
# Example (dev + published): VITE_BROADCAST_EXTENSION_ID=<dev-unpacked-id>,jidmhdmlbjfnblbheglmodhpcjhafjmi
# Leave unset to disable the manual-review button.
VITE_BROADCAST_EXTENSION_ID=
