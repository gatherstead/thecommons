    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.4",
    "vitest": "^4.1.9"
  }
}
