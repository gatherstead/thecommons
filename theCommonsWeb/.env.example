# ── Django API ───────────────────────────────────────────────────────────────
# URL of the Django backend. Defaults to http://127.0.0.1:8000 if unset —
# you only need this if you run Django on a different port or use a staging URL.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_THE_COMMONS_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# Same Neon connection string as backendServer/.env. Better Auth owns the
# `neon_auth` schema; Django reads from `public`. Both point at the same DB.
DATABASE_URL=

# ── Better Auth ──────────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET: any random string (e.g. `openssl rand -hex 32`).
# BETTER_AUTH_URL / NEXT_PUBLIC_BETTER_AUTH_URL: your Next.js origin.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
